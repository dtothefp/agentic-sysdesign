{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "services/chat/**",
      "packages/core/**",
      "pyproject.toml",
      "uv.lock"
    ]
  },
  "deploy": {
    "startCommand": "uv run --package sysdesign-chat uvicorn chat.main:app --host 0.0.0.0 --port $PORT --proxy-headers --forwarded-allow-ips='*'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "deploy": {
        "preDeployCommand": "uv run --package sysdesign-core python packages/core/db/migrate.py"
      }
    }
  }
}
