{
  "name": "sysdesign-agent-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript parallel of the sysdesign chat agent. A ReAct loop over the sysdesign REST API, exposed as a CLI and an SSE server, with runAgent as a native async generator.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.test.json",
    "chat": "tsx src/cli.ts",
    "test": "tsx --test test/*.test.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "knip": "knip"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@hono/node-server": "^1.19.5",
    "hono": "^4.9.9"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "knip": "^5.88.1",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.15",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
