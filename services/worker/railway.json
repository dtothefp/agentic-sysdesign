{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "services/worker/**",
      "packages/core/**",
      "packages/task-contract/**",
      "pyproject.toml",
      "uv.lock"
    ]
  },
  "deploy": {
    "startCommand": "uv run --package sysdesign-worker celery -A worker.celery_app worker --beat --loglevel INFO --concurrency 4",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
