{
  // Host-native default. Points the Python extension at the one shared uv-workspace venv so
  // interpreter selection, test discovery, and the debug configs all agree. In the dev
  // container this is overridden to /home/vscode/.venv (UV_PROJECT_ENVIRONMENT).
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["."]
}
