{
  // Debug configs for Cursor/VS Code, run INSIDE the dev container (Run and Debug panel,
  // or F5). Both point at the container venv (/home/vscode/.venv, set via
  // UV_PROJECT_ENVIRONMENT in .devcontainer/compose.yml).
  //
  // Two deliberate differences from the `make api` / `make worker` commands:
  //   * API: no --reload. The uvicorn reloader spawns a child process and breakpoints
  //     bind to the parent, so they never fire. Restart the debug session after edits.
  //   * Worker: --pool solo. Celery's default prefork pool forks child processes the
  //     debugger can't follow; solo runs every task in the main thread, so breakpoints
  //     inside scrape_influencer/finalize_run actually hit. Tasks run one at a time in
  //     this mode, which is what you want while stepping anyway.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["api.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "DATABASE_URL": "postgresql://lab:lab@db:5432/sysdesign",
        "REDIS_URL": "redis://redis:6379",
        "CELERY_BROKER_URL": "redis://redis:6379/0",
        "CELERY_RESULT_BACKEND": "redis://redis:6379/1"
      }
    },
    {
      "name": "Debug Celery Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": ["-A", "worker.celery_app", "worker", "--loglevel", "INFO", "--pool", "solo"],
      "cwd": "${workspaceFolder}/backend",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "DATABASE_URL": "postgresql://lab:lab@db:5432/sysdesign",
        "REDIS_URL": "redis://redis:6379",
        "CELERY_BROKER_URL": "redis://redis:6379/0",
        "CELERY_RESULT_BACKEND": "redis://redis:6379/1"
      }
    }
  ],
  "compounds": [
    {
      // Launch both, then POST /runs and step through the whole fan-out. Breakpoints to
      // try: api/main.py create_run, worker/tasks.py scrape_influencer + finalize_run,
      // api/main.py stream_run's gen() while a curl -N is attached.
      "name": "Debug API + Worker",
      "configurations": ["Debug API (FastAPI)", "Debug Celery Worker"],
      "stopAll": true
    }
  ]
}
