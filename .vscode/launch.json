{
  // Debug configs for Cursor/VS Code (Run and Debug panel, or F5). Written to run INSIDE the
  // dev container (status bar shows "Container sysdesign"), which is the dev environment for
  // this repo.
  //
  //   * python -> /home/vscode/.venv/bin/python. The container keeps uv's venv OUTSIDE the
  //     bind mount on purpose (UV_PROJECT_ENVIRONMENT in .devcontainer/compose.yml), because
  //     /workspace/.venv is the host's macOS venv and its binaries don't run on Linux. Every
  //     workspace member (api, worker, agent, common) is installed into it as a real package,
  //     so run `uv sync --all-packages` in a container terminal once after pulling new deps.
  //   * Postgres and Redis are the sibling compose services db:5432 / redis:6379.
  //   * The agent reaches the API at localhost:8000 because both run in THIS container.
  //
  // Two deliberate differences from the `moon run ...:dev` commands:
  //   * No --reload on servers. The uvicorn reloader spawns a child process and breakpoints
  //     bind to the parent, so they never fire. Restart the debug session after edits.
  //   * Worker uses --pool solo. Celery's default prefork pool forks children the debugger
  //     can't follow; solo runs every task in the main thread so breakpoints actually hit.
  "version": "0.2.0",
  "configurations": [
    {
      // PRIMARY way to step the ReAct loop. Runs `python -m agent "<prompt>"` synchronously,
      // no async SSE bridge in the way, so breakpoints in agent/loop.py (run_agent),
      // agent/tools.py (the httpx tool calls), and agent/__main__.py hit directly. Edit `args`
      // to change the prompt. Needs the API up (start it first, terminal or the config below);
      // ANTHROPIC_API_KEY and SYSDESIGN_API_KEY load from the repo-root .env automatically.
      "name": "Agent: CLI (step the ReAct loop)",
      "type": "debugpy",
      "request": "launch",
      "module": "agent",
      "args": ["what creators are on the watchlist?"],
      "cwd": "${workspaceFolder}",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "SYSDESIGN_API_URL": "http://localhost:8000"
      }
    },
    {
      // The SSE transport (agent/server.py) on :8100. Breakpoints in the /chat handler and the
      // sync/async bridge (asyncio.to_thread pulls) fire here; attach with
      // `curl -N localhost:8100/chat -H 'Content-Type: application/json' -d '{"message":"..."}'`.
      "name": "Agent: SSE server (:8100)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["agent.server:app", "--host", "0.0.0.0", "--port", "8100"],
      "cwd": "${workspaceFolder}",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "SYSDESIGN_API_URL": "http://localhost:8000"
      }
    },
    {
      "name": "API (FastAPI :8000)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["api.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "DATABASE_URL": "postgresql://lab:lab@db:5432/sysdesign",
        "REDIS_URL": "redis://redis:6379",
        "CELERY_BROKER_URL": "redis://redis:6379/0",
        "CELERY_RESULT_BACKEND": "redis://redis:6379/1"
      }
    },
    {
      "name": "Celery Worker (solo pool)",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": ["-A", "worker.celery_app", "worker", "--loglevel", "INFO", "--pool", "solo"],
      "cwd": "${workspaceFolder}",
      "python": "/home/vscode/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "DATABASE_URL": "postgresql://lab:lab@db:5432/sysdesign",
        "REDIS_URL": "redis://redis:6379",
        "CELERY_BROKER_URL": "redis://redis:6379/0",
        "CELERY_RESULT_BACKEND": "redis://redis:6379/1"
      }
    }
  ],
  "compounds": [
    {
      // Debug the streaming chat path end to end. Both are long-running, so order doesn't
      // matter (the agent only dials the API when a /chat request arrives, by then API is up).
      // Then curl the agent's /chat and step from server.py into loop.py into tools.py.
      "name": "API + Agent SSE",
      "configurations": ["API (FastAPI :8000)", "Agent: SSE server (:8100)"],
      "stopAll": true
    },
    {
      // Debug the Module 2 fan-out. Launch both, POST /runs, and step through create_run
      // (services/api), scrape_influencer + finalize_run (services/worker/worker/tasks.py),
      // and stream_run's gen() while a curl -N is attached.
      "name": "API + Worker",
      "configurations": ["API (FastAPI :8000)", "Celery Worker (solo pool)"],
      "stopAll": true
    }
  ]
}
