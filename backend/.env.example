# Copy to backend/.env and fill in. NEVER commit backend/.env.
# Two consumers, one file:
#   - Python: common/env.py fills os.environ from here on import (env-first,
#     never overrides values compose/Railway already set).
#   - Dev-container shell: .devcontainer/compose.yml env_file loads this whole
#     file into the workspace container, so $SYSDESIGN_API_KEY etc. work in a
#     container terminal. Rebuild the container after edits to refresh those.

# The API's own key (Module 5). The api validates X-API-Key against it, the
# Anthropic vault credential holds the same value for the agent's calls, and
# infra/railway-env.py syncs it to Railway. Rotate in all three places.
SYSDESIGN_API_KEY=

# Managed Agents control plane + the worker's session babysitting (Module 5).
ANTHROPIC_API_KEY=

# Live scrape mode (Module 2).
APIFY_API_KEY=

# Direct psql/dbmate access to the prod Supabase db (drills, prod migrations).
DATABASE_URL_SUPABASE=

# Hosted rating model for prod-parity local runs (Module 4, optional).
GROQ_API_KEY=

# LangSmith tracing (Module 4, optional).
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Railway control plane: env-var sync (project) + preview envs (workspace).
RAILWAY_PROJECT_TOKEN=
RAILWAY_WORKSPACE_TOKEN=

# Supabase project plumbing (infra scripts).
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
