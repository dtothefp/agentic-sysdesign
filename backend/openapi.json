{
  "openapi": "3.1.0",
  "info": {
    "title": "sysdesign API",
    "description": "Thin API over the Module 1 influencer-intelligence schema. FastAPI generates the OpenAPI spec automatically: machine-readable at /openapi.json, Swagger UI at /docs, ReDoc at /redoc. The Module 2 frontend codegens a typed client from that spec.",
    "version": "0.2.0"
  },
