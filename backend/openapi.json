              }
            }
          }
        }
      }
    },
    "/runs/{run_id}/stream": {
      "get": {
        "tags": [
          "runs"
        ],
        "summary": "Stream Run",
        "description": "Server-Sent Events: live progress for one run.\n\nThe refresh-proof pattern, in order:\n  1. subscribe to the Redis channel FIRST, so no delta published during step 2 is lost.\n  2. read the runs row from Postgres and send it as the `snapshot` event. A client that\n     connects late, or reconnects after a page refresh, gets the true current state here.\n  3. if the run is already finished, send `done` and close (nothing more will publish).\n  4. otherwise stream each Redis delta as a `progress` event until `done`.\n\nA refresh just reopens this endpoint. There's no per-user registration to lose: the run_id\nin the URL is the whole subscription, and the snapshot re-establishes state every time.",
        "operationId": "stream_run",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ratings": {
      "get": {
        "tags": [
          "ratings"
        ],
        "summary": "List Ratings",
        "description": "Recent ratings, newest first. min_relevance filters to what the model considered\non-thesis, which is the view the Module 5 digest agent will eventually read.",
        "operationId": "list_ratings",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
