                }
              }
            }
          }
        }
      }
    },
    "/runs": {
      "post": {
        "tags": [
          "runs"
        ],
        "summary": "Create Run",
        "description": "Kick off a fan-out scrape. Creates the runs row, enqueues one Celery task per\ninfluencer plus a fan-in callback that refreshes the rollup, and returns the run_id.\nReturns immediately (202-style): the work happens in the worker, watch it on the stream.\n\nAn unknown provider or a missing provider key is rejected HERE with a 400, before any\ntask is enqueued. Fail at the door: a bad model string should never make it into the\nqueue where it would surface as N retry-looping worker tasks instead of one clear error.",
        "operationId": "create_run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunTrigger"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunCreated"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "runs"
        ],
        "summary": "List Runs",
        "description": "Recent runs, newest first. The dashboard's run history.",
        "operationId": "list_runs",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "default": 20,
              "title": "Limit"
