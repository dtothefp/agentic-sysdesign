{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "packages/agent/**",
      "packages/core/**",
      "pyproject.toml",
      "uv.lock"
    ]
  },
  "deploy": {
    "startCommand": "uv run --package sysdesign-agent uvicorn agent.server:app --host 0.0.0.0 --port $PORT --proxy-headers --forwarded-allow-ips='*'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
